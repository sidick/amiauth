# Editor (clangd) config. The Makefile passes these include paths; mirror them
# here so clangd resolves headers without a compile_commands.json.
CompileFlags:
  Add:
    - "-xc"          # treat headers as C (not Objective-C++) so -std=c99 applies
    - "-std=c99"
    - "-Isrc/core"
    - "-Itests"
