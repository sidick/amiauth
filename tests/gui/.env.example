# Host paths for the GUI test harness (see docker-compose.yml). Copy to .env
# and adjust for your machine. All three are machine-specific; the ROM is also
# copyrighted, so none of them are committed.

# The amiauth repo checkout (mounted as SRC:AmiAuth). Usually this repo.
AMIAUTH_SRC=/Users/simond/src/amiauth

# A bootable Workbench 3.2 directory hard drive with the ReAction classes
# (mounted as DH0:Workbench). Reuses the same install the native Amiberry
# amiauth_32.uae config boots from.
AMIAUTH_WB_HDD=/Users/simond/Documents/Amiberry/HardDrives/amiauth_32

# The A1200 47.115 kickstart (== AmigaOS 3.2), mounted read-only.
AMIAUTH_ROM=/Users/simond/Documents/Amiberry/Kickstarts/A1200.47.115.rom
