; AmiAuth GUI test config for docker-amiberry (KasmVNC-in-a-browser).
;
; A1200 / OS 3.2 (ReAction built in), sized to fill the 1280x960 KasmVNC
; desktop with absolute-mouse enabled so the browser's pointer maps 1:1 onto
; the Amiga screen (no relative-delta fiddling). Two directory hard drives:
;   SRC:AmiAuth  -> the repo (so build/AmiAuthGUI, build/*.vault are visible)
;   DH0:Workbench -> a bootable Workbench 3.2 install with the ReAction classes
; Both are bind-mounted into the container at /amiauth and /workbench; the
; kickstart is bind-mounted into /config/Amiberry/ROMs. See README.md.
;
; Boots straight into emulation: launched as `amiberry -f <this> -G`, and
; use_gui=no as belt-and-suspenders.
config_description=AmiAuth GUI (A1200/OS3.2, 1280x960, absolute mouse)
config_hardware=true
config_host=true
config_version=8.2.2
config_hardware_path=
config_host_path=
config_all_path=
amiberry.rom_path=/config/Amiberry/ROMs/
amiberry.floppy_path=/config/Amiberry/Floppies/
amiberry.hardfile_path=/config/Amiberry/HardDrives/
amiberry.cd_path=/config/Amiberry/CDROMs/
; host-specific
amiberry.middle_mouse=true
amiberry.soundcard=0
amiberry.soundcardname=Null Output
amiberry.expansion_gui_page=scsi_a3000
; common
use_gui=no
use_debugger=false
kickstart_rom_file=A1200.47.115.rom
pcmcia_mb_rom_file=:ENABLED
ide_mb_rom_file=:ENABLED
flash_file=/config/Amiberry/ROMs/
cart_file=
rtc_file=/config/Amiberry/ROMs/
kickshifter=false
scsidevice_disable=false
floppy_volume=33
floppy0=
floppy1=
floppy1type=-1
floppy2=
floppy3=
nr_floppies=0
floppy_speed=0
cd_speed=100
parallel_on_demand=false
serial_on_demand=false
serial_hardware_ctsrts=true
serial_status=false
serial_direct=false
scsi=false
uaeserial=false
sana2=false
sound_output=none
sound_channels=stereo
sound_stereo_separation=7
sound_stereo_mixing_delay=0
sound_max_buff=8192
sound_frequency=44100
sound_interpol=anti
sound_filter=emulated
sound_filter_type=enhanced
sound_volume=0
sound_volume_paula=0
sound_volume_cd=0
sound_volume_ahi=0
sound_volume_midi=0
sound_volume_genlock=0
sound_auto=false
sound_stereo_swap_paula=false
sound_stereo_swap_ahi=false
comp_trustbyte=indirect
comp_trustword=indirect
comp_trustlong=indirect
comp_trustnaddr=indirect
comp_nf=true
comp_constjump=true
comp_flushmode=soft
compfpu=false
comp_catchfault=true
cachesize=0
joyport0=mouse
joyport0autofire=none
joyportfriendlyname0=System mouse
joyportname0=MOUSE0
joyport1=none
joyport1autofire=none
absolute_mouse=mousehack
bsdsocket_emu=true
synchronize_clock=false
maprom=0x0
parallel_postscript_emulation=false
parallel_postscript_detection=false
ghostscript_parameters=
parallel_autoflush=5
gfx_display=0
gfx_display_rtg=0
gfx_framerate=1
gfx_width=1280
gfx_height=960
gfx_x_windowed=0
gfx_y_windowed=0
gfx_width_windowed=1280
gfx_height_windowed=960
gfx_width_fullscreen=800
gfx_height_fullscreen=600
gfx_refreshrate=0
gfx_autoresolution=0
gfx_autoresolution_vga=true
gfx_backbuffers=2
gfx_backbuffers_rtg=1
gfx_vsync=false
gfx_vsyncmode=normal
gfx_vsync_picasso=false
gfx_vsyncmode_picasso=normal
gfx_lores=false
gfx_resolution=hires
gfx_lores_mode=normal
gfx_flickerfixer=false
gfx_linemode=double2
gfx_fullscreen_amiga=true
